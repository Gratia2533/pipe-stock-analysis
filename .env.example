# Public default: direct upstream access. OpenConnector is optional.
DATA_BACKEND=direct

# FinMind is optional; an empty token uses its anonymous access limits.
FINMIND_TOKEN=

# Required only when calling Finnhub-backed global-stock tools.
FINNHUB_API_KEY=

# Shared safety limit for Direct and OpenConnector upstream responses.
UPSTREAM_MAX_RESPONSE_BYTES=4194304

# Optional official-source URL overrides.
TWSE_MARKET_INDEX_URL=https://openapi.twse.com.tw/v1/exchangeReport/MI_INDEX
TWSE_ETF_RANKING_URL=https://openapi.twse.com.tw/v1/ETFReport/ETFRank
TWSE_NEW_LISTING_URL=https://openapi.twse.com.tw/v1/company/newlisting
TWSE_HOLIDAY_SCHEDULE_URL=https://openapi.twse.com.tw/v1/holidaySchedule/holidaySchedule

# OpenConnector advanced mode only. Direct credentials above must remain empty
# when DATA_BACKEND=openconnector; mixed credential modes fail closed.
OPEN_CONNECTOR_BASE_URL=http://127.0.0.1:8001
OPEN_CONNECTOR_RUNTIME_TOKEN=

# MCP transport. Docker Compose overrides MCP_HOST inside the container.
MCP_TRANSPORT=streamable-http
MCP_HOST=127.0.0.1
MCP_PORT=8010
MCP_STREAMABLE_HTTP_PATH=/mcp
MCP_STATELESS_HTTP=true

# Request and cache settings
REQUEST_TIMEOUT_SECONDS=15
REQUEST_MAX_ATTEMPTS=3
REQUEST_RETRY_BASE_SECONDS=0.5
REQUEST_MAX_CONCURRENCY=8
CACHE_TTL_SECONDS=300
CACHE_MAX_ENTRIES=256

# Optional OAuth protection for a private deployment. Leave disabled unless
# you configure all values below with your own public HTTPS URLs and credentials.
FINANCE_OAUTH_ENABLED=false
FINANCE_OAUTH_ISSUER_URL=
FINANCE_OAUTH_RESOURCE_URL=
FINANCE_OAUTH_USERNAME=
FINANCE_OAUTH_PASSWORD=
FINANCE_OAUTH_DATABASE_PATH=/data/oauth/state.sqlite3
FINANCE_OAUTH_SCOPE=finance:read
